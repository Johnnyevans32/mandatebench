# Copy to .env and fill in. The core (mandate signing/checking, stats, tests)
# runs with none of these set. They are only needed once the OpenRouter agent
# layer and persistence land.

# OpenRouter (LLM gateway). Leave blank to use the deterministic mock provider.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://mandatebench.xyz

# Comma-separated OpenRouter slugs to override the default roster (see src/llm/models.ts).
MODELS=

# Runner budget cap (USD) and concurrency.
RUNNER_BUDGET_USD=25
RUNNER_CONCURRENCY=3
RESPONSE_MAX_TOKENS=4096
REASONING_EFFORT=low

# Persistence (added with the server layer).
MONGODB_URI=
