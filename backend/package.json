{
  "name": "mandatebench-backend",
  "version": "0.1.0",
  "description": "Benchmark harness for mandate faithfulness and pre-signature monitorability of agentic-payment LLM agents.",
  "license": "MIT",
  "author": "Evans Eburu",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "demo": "ts-node src/scripts/mandate-demo.ts",
    "scenario": "ts-node src/scripts/scenario-demo.ts",
    "smoke:live": "ts-node src/scripts/smoke-live.ts",
    "duel": "ts-node src/scripts/duel-live.ts",
    "stats-check": "ts-node src/scripts/stats-check.ts",
    "export-snapshot": "ts-node src/scripts/export-snapshot.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.27",
    "dotenv": "^17.4.2",
    "mongoose": "^9.7.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.spec.ts"
    ]
  }
}
